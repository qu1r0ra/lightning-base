@article{islamComprehensiveImageDataset2026,
  title    = {A Comprehensive Image Dataset of Jute Diseases},
  author   = {Islam, Md. Masudul and Sheikh, Md. Ripon},
  year     = 2026,
  month    = feb,
  journal  = {Data in Brief},
  volume   = {64},
  pages    = {112334},
  issn     = {2352-3409},
  doi      = {10.1016/j.dib.2025.112334},
  urldate  = {2026-01-23},
  abstract = {This Data Descriptor presents the Jute Diseases Image Dataset; a curated collection of 1390 high-resolution images aimed at supporting the development of machine learning models for timely identification and accurate diagnosis of jute (Corchorus) plant diseases. The dataset is categorized into five classes: Dieback (300), Holed (300), Mosaic (240), Stem Soft Rot (270), and Fresh (280) representing healthy leaves. Images were captured under varied natural lighting and directional conditions across diverse jute cultivation areas to enhance model generalizability. A rigorous pre-processing pipeline was applied, including uniform resizing to 1024 \texttimes{} 1024 pixels and removal of duplicate images to ensure data integrity. The dataset is organized into two components: a raw, pre-processed set and an augmented train-test split version, enabling immediate use in machine learning workflows. Additionally, Grad-CAM and Guided Grad-CAM techniques were applied to sample images to visualize and validate model attention on disease-relevant regions. This resource addresses the lack of labelled jute disease imagery and supports timely disease management, particularly for stakeholders in Bangladesh and other major jute-producing regions.},
  keywords = {Agriculture,Computer Vision,Crop disease,Image Dataset,Jute dataset,Jute disease},
  file     = {/home/qu1r0ra/Zotero/storage/CD8BWZIB/Islam and Sheikh - 2026 - A comprehensive image dataset of jute diseases.pdf;/home/qu1r0ra/Zotero/storage/KI7T7PUM/S2352340925010480.html}
}

